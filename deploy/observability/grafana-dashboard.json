{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Staging dashboard for Slizen. Core panels support v0.2.2; candidate-only panels say so and show no series on v0.2.2. Proxy-side logical upstream-call avoidance and cache-hit ratio are separate signals; actual origin command volume must come from Redis or Valkey commandstats/exporter. Latency panels are not subtracted to estimate proxy tax.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "All Redis-compatible commands accepted by the selected Slizen targets.",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(slizen_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\"}[$__rate_interval]))",
          "instant": true,
          "legendFormat": "requests",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Proxy request rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "Share of proxy requests recorded with result=error. Tune rollout thresholds to the application's baseline.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(slizen_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",result=\"error\"}[$__rate_interval])) / sum(rate(slizen_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\"}[$__rate_interval]))",
          "instant": true,
          "legendFormat": "errors",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Proxy error rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "GET cache hits divided by GET hits plus misses. This is not the same as logical upstream-call avoidance because coalescing can reduce upstream demand without creating a cache hit.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(slizen_cache_hits_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval])) / (sum(rate(slizen_cache_hits_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval])) + sum(rate(slizen_cache_misses_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval])))",
          "instant": true,
          "legendFormat": "GET hit ratio",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "GET cache-hit ratio",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "One minus Slizen logical upstream GET calls divided by proxy GETs. GET only; MGET is intentionally excluded. This proxy-side estimate does not count go-redis retry attempts or health PINGs; confirm actual origin command volume from Redis or Valkey commandstats/exporter. No traffic returns no value.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * clamp_max(clamp_min(1 - (sum(rate(slizen_upstream_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval])) / sum(rate(slizen_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval]))), 0), 1)",
          "instant": true,
          "legendFormat": "logical GET call avoidance",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "GET upstream-call avoidance",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (result) (rate(slizen_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\"}[$__rate_interval]))",
          "legendFormat": "{{result}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Proxy requests by result",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "End-to-end latency observed inside the Slizen request handler. Do not subtract upstream histogram quantiles from these quantiles.",
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(slizen_request_duration_seconds_bucket{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(slizen_request_duration_seconds_bucket{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "GET latency p95 / p99",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "End-to-end latency of each logical Redis or Valkey call made by Slizen, including pool wait, go-redis retries, and retry backoff. This is not server-only latency.",
