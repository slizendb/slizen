        "w": 12,
        "x": 0,
        "y": 28
      },
      "id": 11,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(slizen_upstream_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval])) / sum(rate(slizen_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval]))",
          "legendFormat": "logical GET call ratio",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "100 * clamp_max(clamp_min(1 - (sum(rate(slizen_upstream_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval])) / sum(rate(slizen_requests_total{job=~\"${job:regex}\",instance=~\"${instance:regex}\",command=\"GET\"}[$__rate_interval]))), 0), 1)",
          "legendFormat": "logical GET call avoidance",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "GET upstream-call ratio / avoidance",
      "type": "timeseries"
    },
