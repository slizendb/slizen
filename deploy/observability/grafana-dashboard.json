    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "description": "Ratio is Slizen logical upstream GET-call rate divided by proxy GET rate; avoidance is one minus that ratio. Both are GET-only proxy-side estimates. They do not count go-redis retry attempts or health PINGs; use Redis or Valkey commandstats/exporter for actual origin volume.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "unit": "percent"
