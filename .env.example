SLIZEN_MODE=observe
SLIZEN_PROXY_LISTEN=0.0.0.0:6380
SLIZEN_PROXY_MAX_COMMAND_BYTES=1048576
SLIZEN_PROXY_MAX_COMMAND_ARGS=1024
SLIZEN_PROXY_MAX_MGET_KEYS=512
SLIZEN_PROXY_MAX_CONNECTIONS=1024
SLIZEN_ADMIN_LISTEN=127.0.0.1:9090
SLIZEN_UPSTREAM_ADDRESS=127.0.0.1:6379
SLIZEN_UPSTREAM_USERNAME=
SLIZEN_UPSTREAM_PASSWORD=
SLIZEN_ADMIN_EXPOSE_RAW_KEYS=false
SLIZEN_KEY_VISIBILITY=hash
# Leave unset for a random process-local HMAC secret. Set through a secret
# manager only when anonymized key IDs must remain stable across restarts.
SLIZEN_KEY_HASH_SECRET=
SLIZEN_LOG_LEVEL=info
